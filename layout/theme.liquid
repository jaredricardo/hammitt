    {% if settings.enable_hammitt_gift_messaging %}
      <script>
        window.addEventListener('DOMContentLoaded', () => {
          // lazy wat of persisting this data
          document.addEventListener('cart:updated', (event) => {
            if(document.querySelector('#hammitt-gift-message-form-input')) {
              if(localStorage.getItem('giftNote')) {
                const storageVal = localStorage.getItem('giftNote')
                document.querySelector('#hammitt-gift-message-form-input').value = storageVal
              }
            }
          })
          class hammittGiftNote extends HTMLElement {
            constructor() {
              super()

                this.giftNoteValue = document.querySelector('input#hammitt-gift-message-form-input')
                this.giftNoteTextArea = document.querySelector('textarea#gift-note-text-area')
                this.saveButton = document.querySelector('#gift-note-save-button')
                this.giftNoteCharLimit = document.querySelector('span#gift-note-char-limit')
                this.giftNoteCheckbox = document.querySelector('input#hammitt-gift-message-checkbox')
                this.checkboxMessageArea = this.querySelector('.checkbox-message-area')
                this.textAreaPlaceholder = this.giftNoteTextArea.placeholder
                this.giftNoteInitData = document.querySelector('.cart-drawer-gift-note')
                this.currentNote = ''

                // Make entire checkbox-message-area clickable
                if(this.checkboxMessageArea) {
                  this.checkboxMessageArea.addEventListener('click', (e) => {
                    // Don't toggle if clicking on the checkbox itself or the trigger button
                    if(e.target === this.giftNoteCheckbox || 
                       e.target.closest('hammitt-gifting-options-drawer-trigger-no-button')) {
                      return
                    }
                    // Toggle the checkbox
                    this.giftNoteCheckbox.checked = !this.giftNoteCheckbox.checked
                    // Trigger the change event
                    this.giftNoteCheckbox.dispatchEvent(new Event('change'))
                  })
                }
    
                this.querySelector('button#gift-note-save-button').addEventListener('click', () => {

                  this.giftNoteTextArea = document.querySelector('textarea#gift-note-text-area')
                  this.saveButton.classList.add('saved')
                  this.saveButton.innerText = 'Saved'
                  document.querySelector('input#hammitt-gift-message-form-input').value = this.currentNote
                  this.textAreaPlaceholder = this.currentNote
                  localStorage.setItem('giftNote', this.currentNote)
                })

                this.giftNoteCheckbox.addEventListener('change', (e) => {
                  if(e.target.checked) return
                  localStorage.removeItem('giftNote')
                  this.giftNoteValue.value = ''
                  this.giftNoteTextArea.value = ''
                  this.giftNoteCharLimit.innerText = `0/500`
                  this.saveButton.classList.remove('saved')
                  this.saveButton.innerText = 'Save'
                })

                this.giftNoteTextArea.addEventListener('input', (e) => {
                  if(e.target.value.length >= 500){
                    this.giftNoteCharLimit.innerText = `500/500`
                    this.saveButton.disabled = true
                    return       
                  } else {
                    this.saveButton.disabled = false
                    this.saveButton.classList.remove('saved')
                    this.saveButton.innerText = 'Save'
                    this.currentNote = e.target.value
                    this.giftNoteCharLimit.innerText = `${e.target.value.length}/500`
                  }
                })
           
                if(localStorage.getItem('giftNote')){
                  if(this.giftNoteValue) {
                    this.giftNoteValue.value = localStorage.getItem('giftNote')
                    this.giftNoteTextArea.value = localStorage.getItem('giftNote')
                    this.giftNoteCheckbox.checked = true
                    this.giftNoteCharLimit.innerText = `${localStorage.getItem('giftNote').length}/500`
                    this.saveButton.classList.add('saved')
                    this.saveButton.innerText = 'Saved'
                  }
                }

                if(this.giftNoteInitData.dataset.serverHasNote === 'false' && !localStorage.getItem('giftNote')){
                  localStorage.removeItem('giftNote')
                  this.giftNoteCheckbox.checked = false
                }

              }
          }
          customElements.define('hammitt-cart-level-gift-note', hammittGiftNote)  
        })
      </script>
    {% endif %}

    {% if settings.enable_hammitt_box_opt_out_cart_level %}
      <script>
        window.addEventListener('DOMContentLoaded', () => {
          // Persist box opt-out data on cart updates
          document.addEventListener('cart:updated', (event) => {
            const boxOptOutInput = document.querySelector('#hammitt-box-opt-out-form-input')
            const boxOptOutCheckbox = document.querySelector('#hammitt-box-opt-out-checkbox')
            const drawerItems = document.querySelector('.drawer__items')
            const cartItemCount = drawerItems ? parseInt(drawerItems.dataset.totalItems || '0') : 0
            
            // Clear boxOptOut when cart is empty to ensure checkbox isn't auto-checked on next add
            if(cartItemCount === 0) {
              localStorage.removeItem('boxOptOut')
              if(boxOptOutInput) boxOptOutInput.value = ''
              if(boxOptOutCheckbox) boxOptOutCheckbox.checked = false
              return
            }
            
            if(boxOptOutInput && boxOptOutCheckbox) {
              // Re-attach event listener after cart update (DOM gets replaced)
              const newCheckbox = document.querySelector('#hammitt-box-opt-out-checkbox')
              if(newCheckbox) {
                // Remove any existing listeners by cloning and replacing
                const clone = newCheckbox.cloneNode(true)
                newCheckbox.parentNode.replaceChild(clone, newCheckbox)
                
                // Attach fresh event listener
                clone.addEventListener('change', (e) => {
                  if(e.target.checked) {
                    const input = document.querySelector('#hammitt-box-opt-out-form-input')
                    if(input) input.value = 'true'
                    localStorage.setItem('boxOptOut', 'true')
                  } else {
                    const input = document.querySelector('#hammitt-box-opt-out-form-input')
                    if(input) input.value = ''
                    localStorage.removeItem('boxOptOut')
                  }
                })
              }
              
              // Update checkbox state from localStorage
              if(localStorage.getItem('boxOptOut') === 'true') {
                boxOptOutInput.value = 'true'
                if(newCheckbox) newCheckbox.checked = true
              } else {
                boxOptOutInput.value = ''
                if(newCheckbox) newCheckbox.checked = false
              }
            }
          })

          class HammittBoxOptOut extends HTMLElement {
            constructor() {
              super()

              this.boxOptOutInput = document.querySelector('input#hammitt-box-opt-out-form-input')
              this.boxOptOutCheckbox = document.querySelector('input#hammitt-box-opt-out-checkbox')
              this.boxOptOutInitData = document.querySelector('.cart-drawer-box-opt-out')

              // Exit early if required elements don't exist
              if(!this.boxOptOutInput || !this.boxOptOutCheckbox || !this.boxOptOutInitData) {
                return
              }

              // Handle checkbox change
              this.boxOptOutCheckbox.addEventListener('change', (e) => {
                if(e.target.checked) {
                  // User opted out of box
                  this.boxOptOutInput.value = 'true'
                  localStorage.setItem('boxOptOut', 'true')
                } else {
                  // User wants the box
                  this.boxOptOutInput.value = ''
                  localStorage.removeItem('boxOptOut')
                }
              })

              // Initialize from localStorage
              if(localStorage.getItem('boxOptOut') === 'true') {
                this.boxOptOutInput.value = 'true'
                this.boxOptOutCheckbox.checked = true
              }

              // Initialize from server data (takes precedence)
              if(this.boxOptOutInitData.dataset.serverHasOptOut === 'true') {
                this.boxOptOutCheckbox.checked = true
                this.boxOptOutInput.value = 'true'
                localStorage.setItem('boxOptOut', 'true')
              } else if(this.boxOptOutInitData.dataset.serverHasOptOut === 'false' && localStorage.getItem('boxOptOut') !== 'true') {
                // Clear if neither server nor localStorage has it
                localStorage.removeItem('boxOptOut')
                this.boxOptOutCheckbox.checked = false
                this.boxOptOutInput.value = ''
              }
            }
          }

          customElements.define('hammitt-box-opt-out', HammittBoxOptOut)
        })
      </script>
    {% endif %}

    <script>
      window.addEventListener('DOMContentLoaded', () => {
        class GiftingOptionsTooltip extends HTMLElement {
          constructor() {
            super()
            this.trigger = null
            this.tooltipContent = null
            this.closeButton = null
            this.isOpen = false
          }

          connectedCallback() {
            this.trigger = this.querySelector('.tooltip-trigger')
            this.tooltipContent = this.querySelector('.tooltip-content')
            this.closeButton = this.querySelector('.icon-close')
            this.attachEventListeners()
          }

          attachEventListeners() {
            // Show tooltip on hover of the trigger (exclamation icon)
            if (this.trigger) {
              this.trigger.addEventListener('mouseenter', () => {
                this.show()
              })
            }

            // Hide tooltip when mouse leaves the tooltip content
            if (this.tooltipContent) {
              this.tooltipContent.addEventListener('mouseleave', () => {
                this.hide()
              })
            }

            // Close on X button click or hover
            if (this.closeButton) {
              this.closeButton.addEventListener('click', (e) => {
                e.stopPropagation()
                this.hide()
              })
            }
          }

          show() {
            this.isOpen = true
            this.classList.add('is-open')
          }

          hide() {
            this.isOpen = false
            this.classList.remove('is-open')
          }
        }

        customElements.define('gifting-options-tooltip', GiftingOptionsTooltip)
      })
    </script>

    {% if settings.enable_hammitt_gift_wrap_upsell_cart_level %}
      <script>
        window.addEventListener('DOMContentLoaded', () => {
          class HammittGiftWrapUpsell extends HTMLElement {
            constructor() {
              super()

              this.giftWrapCheckbox = document.querySelector('input#hammitt-gift-wrap-upsell-checkbox')
              this.giftWrapVid = this.dataset.giftWrapVid
              this.cartHasGiftWrap = this.dataset.cartHasGiftWrap === 'true'

              // Handle checkbox change
              this.giftWrapCheckbox.addEventListener('change', async (e) => {
                if(e.target.checked) {
                  // Add gift wrap to cart
                  await this.addGiftWrapToCart()
                } else {
                  // Remove gift wrap from cart
                  await this.removeGiftWrapFromCart()
                }
              })

              // Initialize checkbox state from server
              this.giftWrapCheckbox.checked = this.cartHasGiftWrap
            }

            connectedCallback() {
              // Listen for cart updates to check if gift wrap should be removed
              document.addEventListener('cart:updated', async () => {
                await this.checkAndRemoveGiftWrapIfOnlyItem()
              })
            }

            getCartElements() {
              // Always get fresh references since cart DOM gets replaced on update
              return {
                drawerWrapper: document.querySelector('.drawer__wrapper'),
                loadingOverlay: document.querySelector('cart-items .loading-overlay')
              }
            }

            showLoading() {
              const { drawerWrapper, loadingOverlay } = this.getCartElements()
              
              if(drawerWrapper) {
                drawerWrapper.classList.add('is-loading')
                drawerWrapper.style.opacity = '0.65'
                drawerWrapper.style.pointerEvents = 'none'
              }
              if(loadingOverlay) {
                loadingOverlay.classList.remove('hidden')
              }
            }

            hideLoading() {
              const { drawerWrapper, loadingOverlay } = this.getCartElements()
              
              if(drawerWrapper) {
                drawerWrapper.classList.remove('is-loading')
                drawerWrapper.style.opacity = '1'
                drawerWrapper.style.pointerEvents = 'initial'
              }
              if(loadingOverlay) {
                loadingOverlay.classList.add('hidden')
              }
            }

            getCartData() {
              // Get cart data from drawer__items data attribute instead of API call
              const drawerItems = document.querySelector('.drawer__items')
              if(drawerItems && drawerItems.dataset.json) {
                try {
                  const cartData = JSON.parse(drawerItems.dataset.json)
                  return cartData
                } catch(error) {
                  console.error('Error parsing cart data:', error)
                  return []
                }
              }
              return []
            }

            async checkAndRemoveGiftWrapIfOnlyItem() {
              try {
                const cartItems = this.getCartData()
                
                // Check if cart only contains gift wrap (and nothing else)
                if(cartItems.length === 1) {
                  const onlyItem = cartItems[0]
                  if(onlyItem.variant_id == this.giftWrapVid) {
                    // Cart only has gift wrap, remove it
                    await this.removeGiftWrapFromCart()
                  }
                } else if(cartItems.length === 0) {
                  // Cart is empty, just uncheck the box
                  this.giftWrapCheckbox.checked = false
                }
              } catch(error) {
                console.error('Error checking gift wrap status:', error)
              }
            }

            async addGiftWrapToCart() {
              this.showLoading()
              
              try {
                const response = await fetch('/cart/add.js', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                  },
                  body: JSON.stringify({
                    items: [{
                      id: this.giftWrapVid,
                      quantity: 1
                    }],
                    sections: "cart-drawer,cart-icon-bubble,main-cart-items"
                  })
                })

                if(response.ok) {
                  const data = await response.json()
                  // Update cart UI with sections data
                  if(typeof cartUpdate === 'function') {
                    await cartUpdate(data)
                  }
                }
              } catch(error) {
                console.error('Error adding gift wrap to cart:', error)
                // Revert checkbox on error
                this.giftWrapCheckbox.checked = false
              } finally {
                this.hideLoading()
              }
            }

            async removeGiftWrapFromCart() {
              this.showLoading()
              
              try {
                const response = await fetch('/cart/change.js', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                  },
                  body: JSON.stringify({
                    id: this.giftWrapVid,
                    quantity: 0,
                    sections: "cart-drawer,cart-icon-bubble,main-cart-items,header"
                  })
                })

                if(response.ok) {
                  const data = await response.json()
                  // Update cart UI with sections data
                  if(typeof cartUpdate === 'function') {
                    await cartUpdate(data)
                  }
                }
              } catch(error) {
                console.error('Error removing gift wrap from cart:', error)
                // Revert checkbox on error
                this.giftWrapCheckbox.checked = true
              } finally {
                this.hideLoading()
              }
            }
          }

          customElements.define('hammitt-gift-wrap-upsell', HammittGiftWrapUpsell)
        })
      </script>
    {% endif %}

