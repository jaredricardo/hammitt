                    "product_tags": [{% for tag in product.tags%}{{ tag | json | replace: "'", "&#39;" }}{% unless forloop.last %},{% endunless %}{% endfor %}],
                    "product_title_type": {{ product_type | json | replace: "'", "&#39;" }},
