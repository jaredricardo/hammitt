<style>
    /* Scroll test winner CSS */

  .pdp-hero-section .pdp-info-col .custom-variant-options ul:not(.swiper) {
    flex-wrap: nowrap !important;
    overflow-x: auto !important;
    padding-bottom: 0.35rem;
  }

  .pdp-hero-section .pdp-info-col .custom-variant-options ul:not(.swiper)::-webkit-scrollbar {
    -webkit-appearance: none;
    width: 100%;
    height: 2px;
    background-color: #EFEFEF;
  }
  .pdp-hero-section .pdp-info-col .custom-variant-options ul:not(.swiper)::-webkit-scrollbar-track  {
    background-color: #EFEFEF;
  }

  .pdp-hero-section .pdp-info-col .custom-variant-options ul:not(.swiper)::-webkit-scrollbar-thumb {
    height: 2px;
    border-radius: 5px;
    background-color: #646464;
  }

  .variant-picker-group-wrapper {
    /* overflow: hidden; */
  }

  /* End scroll test winner CSS */

  .product-colors {
    margin: 20px 0;
  }

  .product-colors ul {
    margin-block-start: 0em;
    padding-inline-start: 0em;
  }

  .product-colors ul li {
    list-style: none;
    display: inline-block;
    border: 1px solid white;
    margin-right: 2px;
  }
  .product-colors li:hover,
  .highlight {
    border: 1px solid #e0dfde;
  }

  .tooltip-block:hover:after {
    border: 1px solid #fc0;
    padding: 3px 6px;
    background: #fffea1;
    content: attr(data-title);
    position: absolute;
    right: -50px;
    top: 100px;
  }

  /* .size_title{font-weight: 600;text-transform: uppercase;margin-bottom: 10px;} */

  .swatch_image-a{
    display: flex;
  }
</style>

{% liquid

  assign has_variant_swaps = false
  assign colorway_collection_handle = product.metafields.custom.colorway_collection.value.handle
  assign colorway_collection = collections[colorway_collection_handle].products
  assign colorway_collection_size = colorway_collection | size
  
  if colorway_collection_size > 1
    assign has_variant_swaps = true
  endif

  assign isShareholder = false
  for tag in customer.tags
    if tag == 'shareholder'
      assign isShareholder = true
    endif
  endfor

  assign current_size = product.metafields.hammitt.size.value | downcase | strip
  assign current_subcategory = product.metafields.custom.product_title_size_subcategory | downcase | strip
  assign initial_variant_group = 'more-colors'

  if current_size == 'mini'
    assign initial_variant_group = 'mini'
  elsif current_size == 'small'
    assign initial_variant_group = 'small'
  elsif current_size == 'medium' and current_subcategory == 'short strap'
    assign initial_variant_group = 'medium-short-strap'
  elsif current_size == 'medium'
    assign initial_variant_group = 'medium'
  elsif current_size == 'large'
    assign initial_variant_group = 'large'
  elsif current_size == 'extra large'
    assign initial_variant_group = 'extra-large'
  elsif current_size == 'shoulder strap'
    assign initial_variant_group = 'shoulder-strap'
  elsif current_size == 'long strap'
    assign initial_variant_group = 'long-strap'
  elsif current_size == 'one size' or current_size == blank
    assign initial_variant_group = 'more-colors'
  endif
%}

{% if has_variant_swaps %}
  <div class="product-colors color_group color_group_block custom-variant-options colorway-optimized">
    {% comment %} color products {% endcomment %}
    <div class="variant-picker-group-wrapper group-more-colors{% if initial_variant_group == 'more-colors' %} initial-active{% endif %}" data-variant-group="more-colors">
      <div class="custom-variant-title">
        <span>{{ 'MORE COLORS:' | upcase }}</span> 
        {% comment %} {% if current_product_size == null %}
          <strong>{{ current_product_color }}</strong>
        {% endif %} {% endcomment %}
        {% if on_special_leather %}
          {% render 'special-care-tooltip' %}
        {% endif %}
      </div>
      
      <ul class="custom-variant-list">
        {% for product in colorway_collection %}

          {% liquid 

            assign isCurrent = false

            ####### new way of assigning product title

            assign product_type = product.metafields.custom.product_title_type
            assign product_color = product.metafields.custom.product_title_color_descriptor
            assign product_size = product.metafields.hammitt.size.value

            #######

            ## Only show products that are not small, medium, or large, if this metafield dosnt exist, then we are on a 
            ## color variant with no sizes.
            if product_size and product_size != 'One Size'
              continue
            endif
    
            # Only show exclusive product if customer has shareholder tag and seo hidden is 1 #
            if isShareholder == false and product.metafields.seo.hidden == 1
              continue 
            endif
    
            if product.metafields.custom.hide_product_all_customers == 1
              continue
            endif

            if product.handle == top_level_handle
              assign isCurrent = true
            endif
    
          -%}
    
          <li data-tooltip="{{ product_color }}" class="{% if isCurrent %} current-swatch {% endif %}">
            <div class="image customSwatch">
              <a 
                href="{{ product.url }}" 
                data-product-id="{{ product.id }}"
                data-product-title="{{ product.title }}" 
                data-sku="{{ product.selected_or_first_available_variant.sku }}"
                data-product-img="{{ product.featured_image | img_url: 'medium' }}"
                aria-label="{{ product_color }}" 
                {% if isCurrent %}style="outline: 1px solid black;"{% endif %} 
                class="swatch_image-a"
                data-test-size="{{ product.images.size }}"
                data-recently-viewed-product-json='{
                  "id": {{ product.id }},
                  "title": {{ product.title | json | replace: "'", "&#39;" }},
                  "handle": {{ product.handle | json }},
                  "featured_image": {{ product.featured_image | image_url: width: 700 | json }},
                  "product_tags": [{% for tag in product.tags%}{{ tag | json | replace: "'", "&#39;" }}{% unless forloop.last %},{% endunless %}{% endfor %}],
                  "product_title_type": {{ product_type | json | replace: "'", "&#39;" }},
                  "product_title_color_descriptor": {{ product_color | json | replace: "'", "&#39;" }},
                  "product_size": {{ product_size | json }},
                  "price": {{ product.selected_or_first_available_variant.price }}
                }'
              >
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 200 | image_tag: preload: true }}
                {% endif %}
              </a>
            </div>
          </li>
    
        {% endfor %}
      </ul>
    </div>
