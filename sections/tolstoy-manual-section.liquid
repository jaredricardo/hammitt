{% liquid 

    # using kyle as the fallback 
    assign publish_id_to_use = '4npieotp5bx8x'
    assign downcased_product_type = product.metafields.custom.product_title_type | downcase

    for block in section.blocks
        if block.settings.product_title_type == downcased_product_type
            assign publish_id_to_use = block.settings.tolstoy_publish_id
        endif
    endfor

-%}

<tolstoy-carousel
  data-tags="{% for tag in product.tags -%}{{ tag | escape }},{%- endfor %}"
  class="tolstoy-carousel"
  data-publish-id="{{ publish_id_to_use }}"
  data-product-id="{{ product.id }}">
</tolstoy-carousel>

{% schema %}
{
    "name": "Tolstoy Manual Section",
    "settings": [],
    "blocks": [
        {
            "type": "tolstoy-id-block",
            "name": "Tolstoy Publish ID Block",
            "settings": [
                {
                    "type": "text",
                    "id": "tolstoy_publish_id",
                    "label": "Tolstoy Publish ID",
                    "info": "Add the publish ID that will map to the below product title type metafield. This will be used to determine which Tolstoy video to show for each product. If left blank, it will default to Kyle's publish ID.",
                },
                {
                    "type": "text",
                    "id": "product_title_type",
                    "label": "Product Title Type Metafield",
                    "info": "Add the name of the product title type metafield (lowercase) that will be used to determine which Tolstoy video to show for each product.will default to looking for 'custom.product_title_type'. EX if you need the above carousel publish ID to appear on all Kyles, you would 'kyle' here."
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Tolstoy Manual Section"
        }
    ]
}
{% endschema %}