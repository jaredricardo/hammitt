{% style %}

  [data-section-id="{{ section.id }}"]:not(hide-show-silhouette-carousel-button) {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  {% if section.settings.top_divider %}
    [data-section-id="{{ section.id }}"]:not(hide-show-silhouette-carousel-button) {
      border-top: 1px solid #E8E8E8;
    }
  {% endif %}

  @media screen and (min-width: 750px) {
    [data-section-id="{{ section.id }}"]:not(hide-show-silhouette-carousel-button) {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  [data-section-id="{{ section.id }}"] .silhouette-carousel__image {
    background-color: {{ section.settings.card_bg_color }};
  }

  {% if section.settings.image_ratio == 'square' %}
    [data-section-id="{{ section.id }}"] .silhouette-carousel__image {
      aspect-ratio: 1 / 1;
      width: 100%;
      object-fit: cover;
    }
  {% elsif section.settings.image_ratio == 'portrait' %}
    [data-section-id="{{ section.id }}"] .silhouette-carousel__image {
      aspect-ratio: 2 / 3;
      width: 100%;
      object-fit: cover;
    }
  {% else %}
    [data-section-id="{{ section.id }}"] .silhouette-carousel__image {
      width: 100%;
      height: auto;
    }
  {% endif %}

{% endstyle %}

{%- capture json -%}
{
  "loop": false,
  {% if section.settings.enable_auto_scroll and section.settings.auto_scroll_speed != 0 %}
    "autoplay": { "delay": {{ section.settings.auto_scroll_speed }}, "disableOnInteraction": false },
  {% endif %}
  "allowSlideNext": true,
  "allowSlidePrev": true,
  "autoHeight": true,
  "grabCursor": true,
  "mousewheel": { "forceToAxis": true },
  "slidesPerView": {{ section.settings.slides_per_view_mobile | plus: 0 }},
  "spaceBetween": 4,
  "breakpoints": {
    "640": {
      "slidesPerView": {{ section.settings.slides_per_view_tablet | plus: 0 }}
    },
    "1025": {
      "slidesPerView": {{ section.settings.slides_per_view_desktop | plus: 0 }}
    }
  }
}
{%- endcapture -%}

{% liquid 

  assign has_collection_specific_slides = false

  if request.page_type == "collection"
    if collection.metafields.custom.silhouette_carousel_items != blank
      assign has_collection_specific_slides = true
    endif
  endif

-%}

<section data-section-id="{{ section.id }}" {% if section.settings.section_anchor_id %} id="{{ section.settings.section_anchor_id }}" {% endif %}>
    {% if section.settings.enable_hide_button %}
        <hide-show-silhouette-carousel-button data-section-id="{{ section.id }}">
            <button class="silhouette-carousel__hide-btn" type="button">Hide</button>
            <span>{% render 'icon-caret' %}</span>
        </hide-show-silhouette-carousel-button>
    {% endif %}
    <div class="silhouette-carousel{% if section.settings.always_show_titles %} always-show-titles{% endif %}">
        <div class="swiper" data-json='{{ json }}'>
            <div class="swiper-wrapper">
              {% if has_collection_specific_slides %}
                {% for item in collection.metafields.custom.silhouette_carousel_items.value %}
                  <a class="swiper-slide silhouette-card" href="{{ item.silhouette_url.value }}">
                    {% if item.silhouette_image != blank %}
                      <img src="{{ item.silhouette_image.value | image_url: width: 800 }}" alt="{{ item.silhouette_title.value }}" class="silhouette-carousel__image" />
                    {% endif %}
                    {% if item.silhouette_title != blank %}
                      <h6 class="silhouette-carousel__hover-text carlson-italic{% if section.settings.always_show_titles %} always-visible{% endif %}">{{ item.silhouette_title.value }}</h6>
                    {% endif %}
                  </a>
                {% endfor %}
              {% else %}
                {% for block in section.blocks %}
                  <a class="swiper-slide silhouette-card" href="{{ block.settings.url }}">
                      {% if block.settings.image != blank %}
                        <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" class="silhouette-carousel__image" />
                      {% endif %}
                      {% if block.settings.title %}
                        <h6 class="silhouette-carousel__hover-text carlson-italic{% if section.settings.always_show_titles %} always-visible{% endif %}">{{ block.settings.title }}</h6>
                      {% endif %}
                  </a>
                {% endfor %}
              {% endif %}
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Silhouette Carousel",
  "enabled_on": {
    "templates": ["product", "collection", "page", "index", "article", "blog", "404", "cart", "search"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_anchor_id",
      "label": "Section Anchor ID (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "checkbox",
      "id": "top_divider",
      "label": "Show top divider",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_auto_scroll",
      "label": "Enable Auto Scroll",
      "default": false
    },
    {
      "type": "number",
      "id": "auto_scroll_speed",
      "label": "Auto Scroll Speed (ms)",
      "default": 5000
    },
    {
      "type": "checkbox",
      "id": "always_show_titles",
      "label": "Always show slide titles",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_hide_button",
      "label": "Enable hide/show button",
      "default": false
    },
    {
      "type": "header",
      "content": "Slides Per View"
    },
    {
      "type": "text",
      "id": "slides_per_view_mobile",
      "label": "Mobile (< 640px)",
      "default": "3.7"
    },
    {
      "type": "text",
      "id": "slides_per_view_tablet",
      "label": "Tablet (≥ 640px)",
      "default": "6.4"
    },
    {
      "type": "text",
      "id": "slides_per_view_desktop",
      "label": "Desktop (≥ 1025px)",
      "default": "6.4"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Ratio",
      "default": "adapt",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ]
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "default": 8
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "default": 8
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 4
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 4
    }
  ],
  "blocks": [
    {
        "type": "silhouette-carousel-item",
        "name": "Silhouette Carousel Item",
        "settings": [
            {
                "type": "image_picker",
                "id": "image",
                "label": "Image"
            },
            {
                "type": "url",
                "id": "url",
                "label": "URL"
            },
            {
                "type": "text",
                "id": "title",
                "label": "Hover State Text",
                "default": "Hover Title"
            }
            // {
            //     "type": "product",
            //     "id": "product",
            //     "label": "Product",
            //     "info": "If a product is selected, quick add will be enabled for this block."
            // }
        ]
    }
  ],
  "presets": [
    {
      "name": "Silhouette Carousel",
    }
  ]
}
{% endschema %}