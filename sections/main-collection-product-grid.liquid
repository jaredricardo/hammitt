{% comment %} {{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }} {% endcomment %}


<link data-href="{{ 'template-collection.css' | asset_url }}" rel="stylesheet" type="text/css" media="all">
<link data-href="{{ 'component-loading-overlay.css' | asset_url }}" rel="stylesheet" type="text/css" media="all">
<link data-href="{{ 'component-card.css' | asset_url }}" rel="stylesheet" type="text/css" media="all">
<link data-href="{{ 'component-price.css' | asset_url }}" rel="stylesheet" type="text/css" media="all">

<link rel="preload" href="{{ 'component-rte.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">

<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

#product-loader {
  display: inline-block;
  margin: 20px auto;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  border: 3px solid #f3f3f3;
  border-top: 3px solid #5b5b62;
  animation: spin 1s linear infinite;
}

/* Spin Animation */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.load-previous{
  width: 100%; 
  text-align: center; 
  z-index: 10; 
  display: block; 
  margin: 0rem 0rem 4rem 0rem;
}

.loader-text{
  border: 1px solid #afafaf;
    border-radius: var(--badge-corner-radius);
    display: inline-block;
    font-size: 1.4rem;
    line-height: 1;
    padding: .6rem 1.3rem;
    text-align: center;
    background-color: transparent;
    color: #333;
    word-break: break-word;
    font-family: var(--font-body-family);
}

@media screen and (max-width: 768px) {
  .load-previous{
    margin: 2.5rem 0rem 2rem 0rem;
  }
}

.collection-breadcrumb {
  display: none; /* currently turned off */
}

.collection-breadcrumb a {
  color: black;
  text-decoration: none;
}


.seo-description-container .description-container {
  transition: height 0.3s ease-in-out;
  max-width: 50%;
}

.seo-description-container a {
  color: black;
  text-decoration: none;
}
.seo-description-container h2 {
  font-weight: 700;
  font-size: 16px;
  text-align: left;
  margin: 1rem 0;
}
.seo-description-container .description-container p,
.seo-description-container .description-container h2,
.seo-description-container .description-container div {
  text-align: left !important; 
  margin: 0;
  font-size: 12px;
  font-weight: 400;
  line-height: 1.2;
  font-family: var(--font-body-family) !important;
}
.seo-description-container .description-container div {
  margin-bottom: 0.75rem;
}

.seo-description-container .description-container br {
  display: none;
}

.seo-description-container .description-container h2 { 
  margin-bottom: 0.75rem !important;
  font-weight: 600 !important;
}

.seo-description-container span.close {
  display: none;
}

.seo-description-container span.open {
  display: flex;
}

.seo-description-container button span {
  min-width: 12px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.seo-description-container:has(.description-container.open) span.close {
  display: flex;
}
.seo-description-container:has(.description-container.open) span.open {
  display: none;
} 

.seo-description-container button {
  display: flex;
  gap: 1rem;
  background-color: transparent;
  border: none;
  padding: 0.5rem 1rem 0.5rem 0;
  font-size: 14px;
  cursor: pointer;
}

@media screen and (max-width: 768px) {
  .seo-description-container.page-width.small-full-width {
    padding: 0 1rem !important;
  }
  .seo-description-container .description-container {
    max-width: 100%;
  }
  .collection-breadcrumb {
    padding: 0 1rem;
  }
  .collection-breadcrumb a {
    font-size: 12px;
  }
}

{%- endstyle -%}

{% if section.settings.use_silhouette_carousel %}
<style>
  /* Grid Silhouette Carousel Styles */
  .grid-silhouette-carousel-wrapper {
    grid-column: 1 / -1;
    width: 100%;
    display: flex;
    gap: 2rem;
    margin: 2rem 0;
  }

  .grid-silhouette-carousel-left {
    width: 20%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 2.5rem;
    justify-content: center;;
  }

  .grid-silhouette-carousel-title {
    font-size: 30px !important;
    font-style: italic;
    font-family: 'Adobe Caslon Pro' !important;
    font-weight: 400;
    margin: 0;
  }

  .grid-silhouette-carousel-link {
    font-size: 16px;
    text-decoration: underline;
    color: black;
    font-weight: 500;
  }

  .grid-silhouette-carousel-right {
    width: 80%;
  }

  .grid-silhouette-carousel {
    padding: 8px 0 8px 4px;
    opacity: 0;
    transition: 300ms ease;
  }

  .grid-silhouette-carousel:has(.swiper-initialized) {
    opacity: 1;
  }

  .grid-silhouette-carousel .swiper:not(.swiper-initialized) {
    overflow: hidden;
  }

  .grid-silhouette-carousel .swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    flex-wrap: nowrap;
  }

  .grid-silhouette-carousel .swiper:not(.swiper-initialized) .swiper-slide {
    width: calc(100% / 3.6);
    flex-shrink: 0;
  }

  @media (min-width: 769px) {
    .grid-silhouette-carousel .swiper:not(.swiper-initialized) .swiper-slide {
      width: calc(100% / 6.5);
    }
  }

  .grid-silhouette-carousel .silhouette-carousel__hover-text {
    opacity: 1;
    text-align: center;
    transition: 300ms ease;
    padding-left: 5px;
    color: black;
    font-weight: 500 !important;
  }

  .grid-silhouette-carousel a {
    text-decoration: none !important;
    display: block;
  }

  .grid-silhouette-carousel .silhouette-carousel__image {
    max-width: 100%;
  }

  .grid-silhouette-card {
    display: block;
  }

  /* Mobile Styles */
  @media screen and (max-width: 768px) {
    .grid-silhouette-carousel-wrapper {
      flex-direction: column;
      gap: 1rem;
    }

    .grid-silhouette-carousel-left {
      width: 100%;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding: 0rem 0.5rem;
    }

    .grid-silhouette-carousel-right {
      width: 100%;
    }

    .grid-silhouette-carousel-title {
      font-size: 22px !important;
    }

    .grid-silhouette-carousel-link {
      font-size: 12px;
    }
  }
</style>
{% endif %}

{% liquid

  assign isShareholder = false
  for tag in customer.tags
    if tag == 'shareholder'
      assign isShareholder = true
    endif
  endfor

%}


{% liquid 

  assign merch_box_one = collection.metafields.custom.merch_box.value
  assign merch_box_two = collection.metafields.custom.merch_box_two.value
  assign additional_merch_boxes = collection.metafields.custom.additional_merch_boxes.value
  assign filters_are_active = false

  for filter in collection.filters
    if filter.active_values.size > 0
      assign filters_are_active = true
    endif
  endfor

  # calculate number of products to show per page in order for there to be no gap due to the merch box spacings

  if merch_box_one and merch_box_one.enable_merch_box
    assign merch_box_one_columns = merch_box_one.number_of_columns
  endif 

  if merch_box_two and merch_box_two.enable_merch_box
    assign merch_box_two_columns = merch_box_two.number_of_columns
  endif

  assign initial_iterable_products_per_page = section.settings.products_per_page
  assign final_products_per_page = initial_iterable_products_per_page | minus: merch_box_one_columns | minus: merch_box_two_columns
  
  ####### if free gift multi select is active, change some of the UI 

  if settings.enable_free_multi_gift_select == true

    assign has_reached_gift_threshold = false
    assign cart_contains_gift_item = false
    assign converted_threshold_price = settings.free_multi_gift_select_threshold_price | times: 100
    assign cart_price_towards_free_gift = cart.total_price

    if settings.free_multi_gift_use_qualifying_tag

      assign qualifying_tag = settings.free_multi_gift_qualifying_tag
      assign cart_price_towards_free_gift = 0

      for item in cart.items
        if item.product.tags contains qualifying_tag
          assign cart_price_towards_free_gift = cart_price_towards_free_gift | plus: item.final_line_price
        endif
      endfor

      assign cart_price_towards_free_gift = cart_price_towards_free_gift

    endif

    if cart_price_towards_free_gift >= converted_threshold_price

      assign has_reached_gift_threshold = true

      # in this instance it is ok to use product_id instead of variant because we dont actually use variants at Hammitt
      for item in cart.items
        for product in settings.free_multi_gift_select_collection.products
          if item.product_id == product.id
            assign cart_contains_gift_item = true
          endif
        endfor
      endfor

    endif
  endif

  assign active_on_collection = false
  assign split_silhouette_carousel_handles = section.settings.carousel_active_handles | split: ','

  for handle in split_silhouette_carousel_handles
    if handle == collection.handle
      assign active_on_collection = true
    endif
  endfor


-%}


{% if section.settings.use_silhouette_carousel %}

  <style>
    #scroll-to-silhouette-carousel-btn {
      position: fixed;
      top: 12vh;
      right: 0;
      width: 40px;
      height: 40px;
      background-color: white;
      color: white;
      border: none;
      font-size: 20px;
      cursor: pointer;
      z-index: 4;
      border: 1px solid black;
      border-top-left-radius: 100px;
      border-bottom-left-radius: 100px;
      padding: 0 0 0 8px !important;
      justify-content: center;
      align-items: center;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
      padding: 0;
    }

    #scroll-to-silhouette-carousel-btn.visible {
      opacity: 1;
      visibility: visible;
      display: flex !important;
    }
    #scroll-to-silhouette-carousel-btn svg {
      width: 50%;
      height: auto;
    }

    @media screen and (max-width: 768px) {
      #scroll-to-silhouette-carousel-btn {
        top: auto;
        bottom: 5vh;
      }
    }
  </style>

  <script>
    window.addEventListener('DOMContentLoaded', () => {
      const scrollButton = document.getElementById('scroll-to-silhouette-carousel-btn');
      const carouselElement = document.getElementById('grid-silhouette-carousel-wrapper');

      if (!scrollButton || !carouselElement) return;

      // Function to check if carousel is past viewport
      function checkCarouselPosition() {
        const carouselRect = carouselElement.getBoundingClientRect();
        const carouselBottom = carouselRect.bottom;
        
        // Show button only if user has scrolled past the carousel
        // (carousel is above the viewport)
        if (carouselBottom < 0) {
          scrollButton.classList.add('visible');
        } else {
          scrollButton.classList.remove('visible');
        }
      }

      // Check position on scroll
      window.addEventListener('scroll', checkCarouselPosition);
      
      // Check position on load
      checkCarouselPosition();

      // Scroll to carousel on button click
      scrollButton.addEventListener('click', () => {
        carouselElement.scrollIntoView({ 
          behavior: 'smooth', 
          block: 'center' 
        });
      });
    });
  </script>

