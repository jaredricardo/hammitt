<div class="section-{{ section.id }}-padding col-wrap" id="product-grid-container">
  {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
    <link data-href="{{ 'component-facets.css' | asset_url }}" rel="stylesheet" type="text/css" media="all">
    {% comment %} {{ 'component-facets.css' | asset_url | stylesheet_tag }} {% endcomment %}

    {% if section.settings.use_new_filters %}
        <script src="{{ 'new-filters.js' | asset_url }}" defer="defer"></script>
      {% else %}
        <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
    {% endif %}
  
    <div class="page-width small-full-width" id="main-collection-filters" data-id="{{ section.id }}">
      <div class="collection-breadcrumb">
        <a style="text-decoration: underline;"href="{{ shop.url }}">Home</a>
        /
        <a href="{{ collection.url }}">{{ collection.title }}</a>
      </div>
      {% if section.settings.use_new_filters %}
        {% render 'new-filters', results: collection, blocks: section.blocks %}
      {% else %}
        {% render 'facets', results: collection, enable_filtering: section.settings.enable_filtering, enable_sorting: section.settings.enable_sorting, collapse_on_larger_devices: section.settings.collapse_on_larger_devices %}
      {% endif %}
    </div>
  {%- endif -%}
  
  <div id="ProductGridContainer">
    {%- paginate collections[collection.handle].products by final_products_per_page -%}
      {%- if collection.products.size == 0 -%}
        <div class="collection collection--empty page-width" id="product-grid" data-id="{{ section.id }}">
          <div class="loading-overlay gradient"></div>
          <div class="title-wrapper center">
            <h2 class="title title--primary">
              {{ 'sections.collection_template.empty' | t }}<br>
              {{ 'sections.collection_template.use_fewer_filters_html' | t: link: collection.url, class: "underlined-link link" }}
            </h2>
          </div>
        </div>
      {%- else -%}
        <div class="collection page-width near-full-width">
          <div class="loading-overlay gradient"></div>
  		  {% assign myIndex = 1 %}

        {% if paginate.previous %}
          <div
            id="AjaxPaginationPrevious"
            class="load-previous"
          >
            <a id="loadprev" href="{{ paginate.previous.url }}">
              {% comment %} <span id="product-loader"></span> {% endcomment %}
              <span class="loader-text">LOAD MORE</span>
            </a>
          </div>
        {% endif %}

          <ul id="product-grid" data-id="{{ section.id }}" class="
            grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down
            {% if section.settings.columns_desktop == 1 %} grid--full-width{% else %}
              grid--{{ section.settings.columns_desktop }}-col-desktop
            {% endif %}">

            {%- for product in collection.products -%}
              {% assign outter_loop_index = forloop.index %}
              {% comment %} Only show exclusive collection products if customer has shareholder tag and seo hidden is 1 {% endcomment %}
              {% if isShareholder == false and product.metafields.seo.hidden == 1  %} 
                {% continue %}
              {% endif %}

              {% if product.metafields.custom.hide_product_all_customers == 1 %}
                {% continue %}
              {% endif %}

              {% comment %} FOR EE GWP  {% endcomment %}
              {% liquid

                # PreOrder
                assign isPreOrderProduct = false 
                
                for tag in product.tags
                  # PreOrder
                  if tag == "ee-pre-order"
                    assign isPreOrderProduct = true
                  endif
                endfor
              %}

              {% assign lazy_load = false %}
              {%- if forloop.index > 2 -%}
                {%- assign lazy_load = true -%}
              {%- endif -%}
              {%- if product.tags contains 'hidden' or product.type == 'hidden' or product.title contains 'Gift wrapping' -%}{%- continue -%}{%- endif -%}
		          {% assign myIndex = myIndex | plus: 1 %}

              {% comment %} MERCH BOX LOGIC / HANDLING {% endcomment %}

              {% comment %} MERCH BOX ONE {% endcomment %}
              {% unless filters_are_active or paginate.current_page > 1 %}
                {% if merch_box_one and merch_box_one.enable_merch_box %}

                  {% if merch_box_one.number_of_columns == 1 and merch_box_one.position_in_grid == forloop.index %}
                    <li class="grid__item">
                      {% render 'merch-box', obj: merch_box_one, index:forloop.index %}
                    </li>
                  {% endif %}

                  {% if merch_box_one.number_of_columns == 2 %}

                    {% assign nearest_odd_number = merch_box_one.position_in_grid %}
                    {% assign mod = nearest_odd_number | modulo: 2 %}
                    {% assign is_even = false %}

                    {% if mod == 0 %}
                      {% assign is_even = true %}
                    {% endif %}

                    {% if is_even  %}
                      {% assign nearest_odd_number = nearest_odd_number | minus: 1 %}
                    {% endif %}

                    {% if nearest_odd_number == forloop.index %}
                      <li class="grid__item">
                        {% render 'merch-box', obj: merch_box_one, index:forloop.index %}
                      </li>
                    {% endif %}
                    
                  {% endif %}

                  {% if merch_box_one.number_of_columns >= 3 %}
                    {% comment %} Snap to the start of the row the configured position falls in {% endcomment %}
                    {% assign mb1_grid_width = section.settings.columns_desktop %}
                    {% assign mb1_row = merch_box_one.position_in_grid | minus: 1 | divided_by: mb1_grid_width %}
                    {% assign mb1_snapped = mb1_row | times: mb1_grid_width | plus: 1 %}
                    {% if mb1_snapped == forloop.index %}
                      <li class="grid__item">
                        {% render 'merch-box', obj: merch_box_one, index: forloop.index %}
                      </li>
                    {% endif %}
                  {% endif %}

                {% endif %}

                {% comment %} MERCH BOX TWO {% endcomment %}
                {% if merch_box_two and merch_box_two.enable_merch_box %}
    
                  {% if merch_box_two.number_of_columns == 1 and merch_box_two.position_in_grid == forloop.index %}
                    <li class="grid__item">
                      {% render 'merch-box', obj: merch_box_two, index: forloop.index %}
                    </li>
                  {% endif %}

                  {% if merch_box_two.number_of_columns == 2 %}

                    {% assign nearest_odd_number = merch_box_two.position_in_grid %}
                    {% assign mod = nearest_odd_number | modulo: 2 %}
                    {% assign is_even = false %}

                    {% if mod == 0 %}
                      {% assign is_even = true %}
                    {% endif %}

                    {% if is_even  %}
                      {% assign nearest_odd_number = nearest_odd_number | minus: 1 %}
                    {% endif %}

                    {% comment %} 
                      In the case of merch box two, we need to account for how many columns merch box 1 is taking up and adjust grid accordingly 
                    {% endcomment %}

                    {% assign true_insertion_index = forloop.index %}

                    {% if merch_box_one and merch_box_one.enable_merch_box %}
                      {% assign true_insertion_index = true_insertion_index | plus: merch_box_one.number_of_columns %}
                    {% endif %}

                    {% if nearest_odd_number == true_insertion_index %}
                      <li class="grid__item">
                        {% render 'merch-box', obj: merch_box_two, index:true_insertion_index  %}
                      </li>
                    {% endif %}
                    
                  {% endif %}

                  {% if merch_box_two.number_of_columns >= 3 %}
                    {% comment %} Snap to the start of the row the configured position falls in {% endcomment %}
                    {% assign mb2_grid_width = section.settings.columns_desktop %}
                    {% assign mb2_row = merch_box_two.position_in_grid | minus: 1 | divided_by: mb2_grid_width %}
                    {% assign mb2_snapped = mb2_row | times: mb2_grid_width | plus: 1 %}
                    {% assign true_insertion_index = forloop.index %}
                    {% if merch_box_one and merch_box_one.enable_merch_box %}
                      {% assign true_insertion_index = true_insertion_index | plus: merch_box_one.number_of_columns %}
                    {% endif %}
                    {% if mb2_snapped == true_insertion_index %}
                      <li class="grid__item">
                        {% render 'merch-box', obj: merch_box_two, index: true_insertion_index %}
                      </li>
                    {% endif %}
                  {% endif %}

                {% endif %}
              {% endunless %}

              {% comment %} Additional Merch Boxes {% endcomment %}
              {% unless additional_merch_boxes == blank or filters_are_active %}
                {% if paginate.current_page > 1 %}
                  {% for additional_merch_box in additional_merch_boxes %}
                    {% if additional_merch_box.page_to_appear_on == paginate.current_page %}

                      {% if additional_merch_box.number_of_columns == 1 and additional_merch_box.position_in_grid == outter_loop_index %}
                        <li class="grid__item">
                          {% render 'merch-box', obj: additional_merch_box, index: forloop.index %}
                        </li>
                      {% endif %}

                      {% if additional_merch_box.number_of_columns == 2 %}

                        {% assign nearest_odd_number = additional_merch_box.position_in_grid %}
                        {% assign mod = nearest_odd_number | modulo: 2 %}
                        {% assign is_even = false %}

                        {% if mod == 0 %}
                          {% assign is_even = true %}
                        {% endif %}

                        {% if is_even  %}
                          {% assign nearest_odd_number = nearest_odd_number | minus: 1 %}
                        {% endif %}

                        {% if nearest_odd_number == outter_loop_index %}
                          <li class="grid__item">
                            {% render 'merch-box', obj: additional_merch_box, index: forloop.index %}
                          </li>
                        {% endif %}
                      {% endif %}

                      {% if additional_merch_box.number_of_columns >= 3 %}
                        {% comment %} Snap to the start of the row the configured position falls in {% endcomment %}
                        {% assign amb_grid_width = section.settings.columns_desktop %}
                        {% assign amb_row = additional_merch_box.position_in_grid | minus: 1 | divided_by: amb_grid_width %}
                        {% assign amb_snapped = amb_row | times: amb_grid_width | plus: 1 %}
                        {% if amb_snapped == outter_loop_index %}
                          <li class="grid__item">
                            {% render 'merch-box', obj: additional_merch_box, index: forloop.index %}
                          </li>
                        {% endif %}
                      {% endif %}

                    {% endif %}
                  {% endfor %}
                {% endif %}
              {% endunless %}

              <li class="grid__item">
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: section.settings.image_ratio,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_vendor: section.settings.show_vendor,
                  show_rating: section.settings.show_rating,
                  lazy_load: lazy_load,
                  index: forloop.index,
                  isPreOrderProduct: isPreOrderProduct,
                  currentPage: paginate.current_page,
                  enable_gifting_card: section.settings.enable_gifting_grid,
                  has_reached_gift_threshold: has_reached_gift_threshold,
                  cart_contains_gift_item: cart_contains_gift_item,
                  converted_threshold_price: converted_threshold_price
                %}
              </li>

              {% comment %} SILHOUETTE CAROUSEL - Render after products {% endcomment %}
              {% unless filters_are_active or paginate.current_page > 1 %}
                {% if section.settings.use_silhouette_carousel and active_on_collection %}
                  {% comment %} Calculate cumulative grid slots used so far {% endcomment %}
                  {% assign cumulative_slots = forloop.index %}
                  
                  {% comment %} Add merch box one columns if it has rendered (at or before current position) {% endcomment %}
                  {% if merch_box_one and merch_box_one.enable_merch_box %}
                    {% if merch_box_one.number_of_columns == 1 and merch_box_one.position_in_grid <= forloop.index %}
                      {% assign cumulative_slots = cumulative_slots | plus: 1 %}
                    {% elsif merch_box_one.number_of_columns == 2 %}
                      {% assign mb1_nearest_odd = merch_box_one.position_in_grid %}
                      {% assign mb1_mod = mb1_nearest_odd | modulo: 2 %}
                      {% if mb1_mod == 0 %}
                        {% assign mb1_nearest_odd = mb1_nearest_odd | minus: 1 %}
                      {% endif %}
                      {% if mb1_nearest_odd <= forloop.index %}
                        {% assign cumulative_slots = cumulative_slots | plus: 2 %}
                      {% endif %}
                    {% elsif merch_box_one.number_of_columns >= 3 %}
                      {% assign mb1_grid_width = section.settings.columns_desktop %}
                      {% assign mb1_row = merch_box_one.position_in_grid | minus: 1 | divided_by: mb1_grid_width %}
                      {% assign mb1_snapped = mb1_row | times: mb1_grid_width | plus: 1 %}
                      {% if mb1_snapped <= forloop.index %}
                        {% assign cumulative_slots = cumulative_slots | plus: merch_box_one.number_of_columns %}
                      {% endif %}
                    {% endif %}
                  {% endif %}
                  
                  {% comment %} Add merch box two columns if it has rendered {% endcomment %}
                  {% if merch_box_two and merch_box_two.enable_merch_box %}
                    {% if merch_box_two.number_of_columns == 1 and merch_box_two.position_in_grid <= forloop.index %}
                      {% assign cumulative_slots = cumulative_slots | plus: 1 %}
                    {% elsif merch_box_two.number_of_columns == 2 %}
                      {% assign mb2_nearest_odd = merch_box_two.position_in_grid %}
                      {% assign mb2_mod = mb2_nearest_odd | modulo: 2 %}
                      {% if mb2_mod == 0 %}
                        {% assign mb2_nearest_odd = mb2_nearest_odd | minus: 1 %}
                      {% endif %}
                      {% if mb2_nearest_odd <= forloop.index %}
                        {% assign cumulative_slots = cumulative_slots | plus: 2 %}
                      {% endif %}
                    {% elsif merch_box_two.number_of_columns >= 3 %}
                      {% assign mb2_grid_width = section.settings.columns_desktop %}
                      {% assign mb2_row = merch_box_two.position_in_grid | minus: 1 | divided_by: mb2_grid_width %}
                      {% assign mb2_snapped = mb2_row | times: mb2_grid_width | plus: 1 %}
                      {% if mb2_snapped <= forloop.index %}
                        {% assign cumulative_slots = cumulative_slots | plus: merch_box_two.number_of_columns %}
                      {% endif %}
                    {% endif %}
                  {% endif %}
                  
                  {% comment %} Render at slot 9 (after 8 slots filled) or at the end {% endcomment %}
                  {% assign should_render_carousel = false %}
                  {% if cumulative_slots == 8 %}
                    {% assign should_render_carousel = true %}
                  {% elsif forloop.last and cumulative_slots < 8 %}
                    {% assign should_render_carousel = true %}
                  {% endif %}
                  
                  {% if should_render_carousel %}
                    <li class="grid__item grid-silhouette-carousel-wrapper" id="grid-silhouette-carousel-wrapper">
                    <div class="grid-silhouette-carousel-left">
                      {% if section.settings.silhouette_carousel_title != blank %}
                        <h3 class="grid-silhouette-carousel-title">{{ section.settings.silhouette_carousel_title }}</h3>
                      {% endif %}
                      {% if section.settings.silhouette_carousel_link_url != blank and section.settings.silhouette_carousel_link_text != blank %}
                        <a href="{{ section.settings.silhouette_carousel_link_url }}" class="grid-silhouette-carousel-link">{{ section.settings.silhouette_carousel_link_text }}</a>
                      {% endif %}
                    </div>
                    <div class="grid-silhouette-carousel-right">
                      {%- capture json -%}
                      {
                        "loop": false,
                        "allowSlideNext": true,
                        "allowSlidePrev": true,
                        "autoHeight": true,
                        "grabCursor": true,
                        "mousewheel": { "forceToAxis": true },
                        "slidesPerView": 3.6,
                        "spaceBetween": 4,
                        "breakpoints": {
                          "768": {
                            "slidesPerView": 6.5
                          }
                        }
                      }
                      {%- endcapture -%}
                      <div class="grid-silhouette-carousel always-show-titles">
                        <div class="swiper" data-json='{{ json }}'>
                          <div class="swiper-wrapper">
                            {% for block in section.blocks %}
                              {% if block.type == 'silhouette-carousel-item' %}
                                <a class="swiper-slide grid-silhouette-card" href="{{ block.settings.silhouette_url }}">
                                  {% if block.settings.image != blank %}
                                    <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" class="silhouette-carousel__image" loading="lazy" />
                                  {% endif %}
                                  {% if block.settings.title != blank %}
                                    <h6 class="silhouette-carousel__hover-text carlson-italic always-visible">{{ block.settings.title }}</h6>
                                  {% endif %}
                                </a>
                              {% endif %}
                            {% endfor %}
                          </div>
                        </div>
                      </div>
                    </div>
                  </li>
                  {% endif %}
                {% endif %}
              {% endunless %}
            
            
            {%- endfor -%}
          </ul>
  
          {%- if paginate.pages > 1 -%}
            {% render 'pagination', paginate: paginate, anchor: '' %}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
    {% unless collection.description == blank%}
      <div class="seo-description-container page-width small-full-width">
        <h2>{{ collection.title }}</h2>
        <div class="description-container">
          <p>{{ collection.description }}</p>
        </div>
      </div>
    {% endunless %}
  </div>
</div>

<script>
  window.addEventListener('DOMContentLoaded', () => {

    const collectionSeoButton = document.querySelector('.seo-description-container button')
    
    if(!collectionSeoButton) return
    
    collectionSeoButton.addEventListener('click', () => {
      openSeoDescription()
    })

    function openSeoDescription() { 

    return

      const descriptionContainer = document.querySelector('.seo-description-container .description-container')
      const neededHeight = descriptionContainer.scrollHeight
    
      if(descriptionContainer.classList.contains('open')) {
        descriptionContainer.style.height = '0px'
        descriptionContainer.classList.remove('open')

        descriptionContainer.style.minHeight = 'unset'

      } else {
        setTimeout(() => {
          descriptionContainer.style.minHeight = 'max-content'
        }, 300)
        document.querySelector('.seo-description-container .description-container').classList.add('open')
        document.querySelector('.seo-description-container .description-container').style.height = `${neededHeight}px`
      }
    }

  })
</script>

{% if section.settings.enable_gifting_grid %}
  <script>
    document.addEventListener('cart:updated', () => {
      fetch(window.location.pathname + "?sections={{ section.id }}")
        .then(res => res.json())
        .then(data => {
          const parser = new DOMParser()
          const doc = parser.parseFromString(data['{{ section.id }}'], 'text/html')
          const newProductGrid = doc.querySelector('#product-grid')
          const currentProductGrid = document.querySelector('#product-grid')    
          if(!newProductGrid || !currentProductGrid) return
          currentProductGrid.innerHTML = newProductGrid.innerHTML
        })

    })
  </script>
{% endif %}

{% schema %}
{
  "name": "Product Grid",
  "class": "section",
