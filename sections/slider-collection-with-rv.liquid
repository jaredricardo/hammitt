{{ 'slider-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .swiper .swiper-button-next {
      right: var(--swiper-navigation-sides-offset, 25px);
    }
    #shopify-section-{{ section.id }} .swiper .swiper-button-prev {
      left: var(--swiper-navigation-sides-offset, 25px);
    }
    #shopify-section-{{ section.id }} .swiper .swiper-button-next::after,
    #shopify-section-{{ section.id }} .swiper .swiper-button-prev::after {
      font-size: 30px;
    }
    #shopify-section-{{ section.id }} .swiper .swiper-button-next,
    #shopify-section-{{ section.id }} .swiper .swiper-button-prev {
      display: block;
      top: calc(50% - 5rem);
    }
  }
  .combined-slider__tabs {
    list-style: none;
    margin: 0 0 20px;
    padding: 0;
    display: flex;
    gap: 28px;
    justify-content: center;
  }

  .combined-slider__tabs .tab-item button {
    display: inline-block;
    background: none;
    border: none;
    padding: 0 0 4px;
    cursor: pointer;
    text-decoration: none;
    font-size: inherit;
    color: inherit;
    font-family: 'Adobe Carlson Italic' !important;
    font-size: 32px !important;
    line-height: 1;
  }
  .combined-slider__tabs .tab-item.active button {
    border-bottom: 1.5px solid black;
  }

  @media screen and (max-width: 769px) {
      .combined-slider__tabs .tab-item button {
        font-size: 18px !important;
      }
  }

{%- endstyle -%}

{%- capture sc_json -%}
{
  "slidesPerView": 1,
  "spaceBetween": 20,
  "freeMode": true,
  "mousewheel": false,
  "loop": false,
  "scrollbar": {
    "el": "#sc-scrollbar-{{ section.id }}",
    "draggable": true
  },
  "effect": "slide",
  "navigation": {
    "nextEl": "#sc-next-{{ section.id }}",
    "prevEl": "#sc-prev-{{ section.id }}"
  },
  "breakpoints": {
    "0": { "slidesPerView": {{ section.settings.slides_per_view_mobile }}, "spaceBetween": 4 },
    "750": { "slidesPerView": {{ section.settings.slides_per_view_tablet }}, "spaceBetween": 4 },
    "990": { "slidesPerView": {{ section.settings.slides_per_view_desktop }}, "spaceBetween": 4 }
  }
}
{%- endcapture -%}

{%- capture rv_json -%}
{
  "slidesPerView": 1,
  "spaceBetween": 20,
  "freeMode": true,
  "mousewheel": false,
  "loop": false,
  "scrollbar": {
    "el": "#rv-scrollbar-{{ section.id }}",
    "draggable": true
  },
  "effect": "slide",
  "navigation": {
    "nextEl": "#rv-next-{{ section.id }}",
    "prevEl": "#rv-prev-{{ section.id }}"
  },
  "breakpoints": {
    "0": { "slidesPerView": {{ section.settings.slides_per_view_mobile }}, "spaceBetween": 4 },
    "750": { "slidesPerView": {{ section.settings.slides_per_view_tablet }}, "spaceBetween": 4 },
    "990": { "slidesPerView": {{ section.settings.slides_per_view_desktop }}, "spaceBetween": 4 }
  }
}
{%- endcapture -%}

<div class="combined-slider-section section-wrap section-{{ section.id }}-padding">
  <div class="">

    <ul class="combined-slider__tabs">
      <li class="tab-item active">
        <button type="button" data-href="collection">{{ section.settings.tab1_title | default: 'You May Also Like' }}</button>
      </li>
      <li class="tab-item">
        <button type="button" data-href="recently-viewed">{{ section.settings.tab2_title | default: 'Recently Viewed' }}</button>
      </li>
    </ul>

    <!-- Collection panel (default active) -->
    <div data-panel="collection">
      <div class="section-productgrid-wrap">
        <div class="swiper" data-json='{{ sc_json }}'>
          <div class="section-productgrid swiper-wrapper">
            {% for product in section.settings.collection.products limit: section.settings.max_products %}
              {%- liquid
                assign isPreOrderProduct = false
                for tag in product.tags
                  if tag == "ee-pre-order"
                    assign isPreOrderProduct = true
                  endif
                endfor
              -%}
              <div id="block-{{ product.id }}" class="swiper-slide">
                {%- render 'card-product',
                  card_product: product,
                  show_secondary_image: section.settings.show_secondary_image,
                  media_aspect_ratio: section.settings.image_ratio,
                  hide_price: section.settings.hide_price,
                  hide_tag: section.settings.hide_tag,
                  hide_subtitle: section.settings.hide_subtitle,
                  hide_quick_add: section.settings.hide_quick_add,
                  isPreOrderProduct: isPreOrderProduct
                -%}
              </div>
            {% endfor %}
          </div>
          <div class="swiper-button-next" id="sc-next-{{ section.id }}"></div>
          <div class="swiper-button-prev" id="sc-prev-{{ section.id }}"></div>
        </div>
        <div class="swiper-scrollbar" id="sc-scrollbar-{{ section.id }}"></div>
      </div>
    </div>

    <!-- Recently Viewed panel (hidden by default) -->
    <div data-panel="recently-viewed" class="hidden">
      <div class="section-productgrid-wrap">
        <combined-recently-viewed
          class="swiper special-init-swiper"
          data-json='{{ rv_json }}'
          data-image-ratio='{{ section.settings.image_ratio }}'
          data-hide-price='{{ section.settings.hide_price }}'
          data-hide-subtitle='{{ section.settings.hide_subtitle }}'
          data-hide-quick-add='{{ section.settings.hide_quick_add }}'
        >
          <div class="swiper-wrapper"></div>
          <div class="swiper-button-next" id="rv-next-{{ section.id }}"></div>
          <div class="swiper-button-prev" id="rv-prev-{{ section.id }}"></div>
        </combined-recently-viewed>
        <div class="swiper-scrollbar" id="rv-scrollbar-{{ section.id }}"></div>
      </div>
    </div>

  </div>
</div>

<script src="{{ 'slider-collection-with-rv.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Slider Collection + RV",
  "class": "slider-collection-with-rv",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "tab1_title",
      "label": "Collection tab label",
      "default": "You May Also Like"
    },
    {
      "type": "text",
      "id": "tab2_title",
      "label": "Recently Viewed tab label",
      "default": "Recently Viewed"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 1,
      "max": 30,
      "step": 1,
      "label": "Max products",
      "default": 10
    },
    {
      "type": "header",
      "content": "Product card settings"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image on hover",
      "default": true
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adapt" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "adapt",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "hide_price",
      "label": "Hide price",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_tag",
      "label": "Hide product tag",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_subtitle",
      "label": "Hide subtitle",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_quick_add",
      "label": "Hide quick add",
      "default": false
    },
    {
      "type": "header",
      "content": "Slides per view"
    },
    {
      "type": "range",
      "id": "slides_per_view_mobile",
      "min": 1,
      "max": 6,
      "step": 0.1,
      "label": "Mobile (0px+)",
      "default": 2.2
    },
    {
      "type": "range",
      "id": "slides_per_view_tablet",
      "min": 1,
      "max": 6,
      "step": 0.1,
      "label": "Tablet (750px+)",
      "default": 2.2
    },
    {
      "type": "range",
      "id": "slides_per_view_desktop",
      "min": 1,
      "max": 6,
      "step": 0.1,
      "label": "Desktop (990px+)",
      "default": 4
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Slider Collection + Recently Viewed"
    }
  ]
}
{% endschema %}
